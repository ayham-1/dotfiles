<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/questionTitle"
        android:layout_width="235dp"
        android:layout_height="83dp"
        android:ems="10"
        android:gravity="start|top"
        android:inputType="textMultiLine"
		app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="91dp"
        android:layout_height="56dp"
        android:text="Question Title:"
        android:textAlignment="center"
		app:layout_constraintRight_toRightOf="@+id/questionTitle" />

    <EditText
        android:id="@+id/correctAnswer"
        android:layout_width="235dp"
        android:layout_height="83dp"
        android:ems="10"
        android:gravity="start|top"
        android:inputType="textMultiLine"
		app:layout_constraintTop_toBottomOf="@+id/questionTitle" />

    <TextView
        android:layout_width="91dp"
        android:layout_height="56dp"
        android:text="Correct Answer:"
		app:layout_constraintRight_toRightOf="@+id/correctText" />

    <EditText
        android:id="@+id/wrongAnswers"
        android:layout_width="236dp"
        android:layout_height="126dp"
        android:ems="10"
        android:gravity="start|top"
        android:inputType="textMultiLine"
		app:layout_constraintTop_toBottomOf="@+id/correctAnswer" />

    <TextView
        android:layout_width="91dp"
        android:layout_height="56dp"
        android:text="Wrong Answers:"
		app:layout_constraintRight_toRightOf="@+id/wrongAnswers" />

    <TextView
        android:id="@+id/questionNumberText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question Number:"
		app:layout_constraintLeft_toRightOf="@+id/questionNumberText" />

    <TextView
        android:id="@+id/questionNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0000"
        android:textSize="24sp" />

    <Button
        android:id="@+id/saveBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        tools:layout_editor_absoluteX="179dp"
        tools:layout_editor_absoluteY="561dp" />

    <Button
        android:id="@+id/nextBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next"
        tools:layout_editor_absoluteX="275dp"
        tools:layout_editor_absoluteY="561dp" />

    <Button
        android:id="@+id/prevBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Previous"
        tools:layout_editor_absoluteX="60dp"
        tools:layout_editor_absoluteY="561dp" />

    <Button
        android:id="@+id/button4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share"
        tools:layout_editor_absoluteX="179dp"
        tools:layout_editor_absoluteY="609dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
