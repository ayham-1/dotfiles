#preamble {
	max-width: var(--genwidth);
	margin: auto;
	background: var(--altbg);
	margin: auto;
	border-radius: 5px;
}
nav {
	text-align: center;
	font-variant: small-caps;
	clear: both;
	vertical-align: middle ;
	text-align: left ;
	font-size: large ;
}
a {
	color: #36f433;
	text-decoration: none;
}
nav ul a img {
	max-height: 1em;
	max-width: 1em;
	vertical-align: middle;
}

nav a:hover li, #tagcloud a:hover li {
	background: steelblue ;
	color: black ;
}
nav a {
	text-align: center;
	margin: .5em;
	background: black;
	border-radius: 5px;
	padding: 2px;
}
