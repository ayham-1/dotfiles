#!/bin/bash

# Dmenu for selecting which browser to open.

Browsers='1. firefox
2. surf-open'

Chosen=$(printf '%s' "$Browsers" \
	| dmenu -i -l 20 -p 'Select browser:')
[ -z "$Chosen" ] && exit 1

case $Chosen in
	'1. firefox') firefox "$@";;
	'2. surf-open') surf-open "$@";;
	*) eval "$Chosen" "$@";;
esac
